# Gemini AI (Google) - used for the conversational trip builder
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here

# Gemini model — change to switch all AI features at once
GEMINI_MODEL=your-gemini-model-here

# Gemini model for story generation — use a more capable model for creative writing
GEMINI_STORY_MODEL=your-gemini-story-model-here

# Data backend: "json" (default, file-based) or "firestore" (GCP, future)
# DATA_BACKEND=json
